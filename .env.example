# Notion 集成 Token（https://www.notion.so/my-integrations 创建）
NOTION_TOKEN=secret_xxx

# Notion 数据库 ID（数据库链接中 32 位的那段）
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书自动化流程 Webhook 触发器地址
FEISHU_WEBHOOK=https://www.feishu.cn/flow/api/trigger-webhook/xxxx

# 可选：当 Notion 中的属性名与默认值不同时覆盖（默认 摘要 / 下周最重要任务）
# NOTION_PROP_SUMMARY=摘要
# NOTION_PROP_NEXT_TASK=下周最重要任务
